---
const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const waLink = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/propiedades', label: 'Propiedades' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 bg-gray-900 text-white">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/">
      <img src="/logo.svg" alt="DG Inmobiliaria" class="h-8 w-auto" />
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="text-sm hover:text-brand-500 transition-colors">{label}</a>
        </li>
      ))}
    </ul>

    <a
      href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-green-500 hover:bg-green-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
    >
      WhatsApp
    </a>
  </nav>
</header>
