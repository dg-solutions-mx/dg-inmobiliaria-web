---
import Brand from './Brand.astro';
import { MessageCircle, Menu } from 'lucide-astro';
const WHATSAPP_URL = 'https://wa.me/526699334134?text=Hola%2C%20me%20interesa%20conocer%20opciones%20de%20vivienda%20en%20Mazatl%C3%A1n.';
const path = Astro.url.pathname;
const isHome = path === '/';
const isPropiedades = path.startsWith('/propiedades');
const { opaque = false } = Astro.props;
---
<header class="site-header" data-header {...(opaque ? {'data-header-always-scrolled': ''} : {})}>
  <div class="site-header__inner container">
    <Brand />
    <nav class="desktop-nav" aria-label="Navegación principal">
      <a class:list={[{ active: isHome }]} href="/#inicio">Inicio</a>
      <a href="/#como-te-ayudamos">Cómo te ayudamos</a>
      <a class:list={[{ active: isPropiedades }]} href="/propiedades">Propiedades</a>
      <a href="/#proceso">Proceso</a>
      <a href="/#contacto">Contacto</a>
    </nav>
    <a class="button button--gold header-whatsapp" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">
      <MessageCircle size={17} stroke-width={1.5} />
      <span>Contáctanos</span>
    </a>
    <button class="menu-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" data-menu-toggle>
      <Menu size={26} stroke-width={1.5} />
    </button>
  </div>
  <nav class="mobile-menu" aria-label="Navegación móvil" data-mobile-menu>
    <a href="/#inicio">Inicio</a>
    <a href="/#como-te-ayudamos">Cómo te ayudamos</a>
    <a href="/propiedades">Propiedades</a>
    <a href="/#proceso">Proceso</a>
    <a href="/#contacto">Contacto</a>
    <a class="button button--gold" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">Escríbenos por WhatsApp</a>
  </nav>
</header>
