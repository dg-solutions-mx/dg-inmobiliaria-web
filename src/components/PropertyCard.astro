---
interface Props {
  slug: string;
  title: string;
  zone: string;
  price: number;
  imageUrl: string;
  type: 'terreno' | 'casa' | 'desarrollo';
}

const { slug, title, zone, price, imageUrl, type } = Astro.props;

const formattedPrice = new Intl.NumberFormat('es-MX', {
  style: 'currency',
  currency: 'MXN',
  maximumFractionDigits: 0,
}).format(price);
---

<article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">
  <a href={`/propiedades/${slug}`}>
    <img
      src={imageUrl}
      alt={title}
      class="w-full h-52 object-cover"
      loading="lazy"
    />
  </a>
  <div class="p-4">
    <span class="text-xs text-brand-600 font-medium uppercase tracking-wide">{type} · {zone}</span>
    <h3 class="font-semibold text-gray-900 mt-1 text-lg leading-snug">
      <a href={`/propiedades/${slug}`} class="hover:text-brand-600 transition-colors">{title}</a>
    </h3>
    <p class="text-brand-700 font-bold text-xl mt-2">{formattedPrice}</p>
    <a
      href={`/propiedades/${slug}`}
      class="mt-4 inline-block text-sm text-brand-600 hover:underline font-medium"
    >
      Ver detalles →
    </a>
  </div>
</article>
