---
import { Home, Search, UserRound, ArrowRight } from 'lucide-astro';

const cards = [
  { image: '/assets/card-casa.webp', Icon: Home, title: 'Comprar tu casa', text: 'Te ayudamos a encontrar una opción de vivienda de acuerdo con tu presupuesto y forma de compra.', action: 'Quiero orientación', href: '#contacto' },
  { image: '/assets/card-explorar.webp', Icon: Search, title: 'Explorar opciones', text: 'Conoce alternativas y desarrollos en Mazatlán que se adapten a lo que estás buscando.', action: 'Ver propiedades', href: '/propiedades' },
  { image: '/assets/card-asesoria.webp', Icon: UserRound, title: 'Asesoría personalizada', text: 'Recibe atención directa para resolver dudas y avanzar con mayor confianza.', action: 'Hablar con un asesor', href: '#contacto' },
];
---
<section class="help section" id="como-te-ayudamos">
  <div class="container">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">Cómo te ayudamos</p>
      <h2>Encontramos el espacio ideal para tu vida</h2>
    </div>
    <div class="help-grid">
      {cards.map((card, index) => (
        <article class="help-card" data-reveal style={`--delay:${index * 120}ms`}>
          <div class="help-card__photo">
            <img src={card.image} alt="" loading="lazy" />
          </div>
          <div class="help-card__icon"><card.Icon size={25} stroke-width={1.5} /></div>
          <div class="help-card__body">
            <h3>{index + 1}. {card.title}</h3>
            <p>{card.text}</p>
            <a href={card.href}>{card.action} <ArrowRight size={16} stroke-width={1.5} /></a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
