---
import { Building2, Handshake, MessageCircle, KeyRound } from 'lucide-astro';

const benefits = [
  { Icon: Building2, title: 'Expertos locales', text: 'Conocemos Mazatlán y su mercado.' },
  { Icon: Handshake, title: 'Asesoría personalizada', text: 'Te acompañamos en cada paso.' },
  { Icon: MessageCircle, title: 'Atención por WhatsApp', text: 'Comunicación rápida y directa.' },
  { Icon: KeyRound, title: 'Orientación confiable', text: 'Encuentra tu vivienda ideal.' },
];
---
<section class="trust-wrap" id="confianza">
  <div class="trust-bar container" data-reveal>
    {benefits.map((benefit, i) => (
      <article class="trust-item" style={`--delay:${i * 85}ms`}>
        <benefit.Icon size={37} stroke-width={1.5} />
        <div>
          <h3>{benefit.title}</h3>
          <p>{benefit.text}</p>
        </div>
      </article>
    ))}
  </div>
</section>
