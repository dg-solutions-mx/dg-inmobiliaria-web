  {name === 'building' && <><path d="M3 21h18" /><path d="M6 21V4h8v17" /><path d="M14 9h4v12" /><path d="M9 8h2M9 12h2M9 16h2" /></>}
  {name === 'handshake' && <><path d="m11 17 2 2a2 2 0 0 0 3-3l-3.3-3.3" /><path d="m12 12-2 2a2 2 0 1 1-3-3l3-3a3 3 0 0 1 4 0l.5.5a3 3 0 0 0 4 0L20 7" /><path d="M2 8h4l2 2" /><path d="M22 8h-3l-2 2" /></>}
