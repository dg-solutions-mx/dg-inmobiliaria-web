  {name === 'home' && <><path d="m3 11 9-8 9 8" /><path d="M5 10v10h14V10" /><path d="M10 20v-6h4v6" /></>}
  {name === 'search' && <><circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" /></>}
  {name === 'user' && <><circle cx="12" cy="8" r="4" /><path d="M5 21c.8-4 3.2-6 7-6s6.2 2 7 6" /></>}
  {name === 'sun' && <><circle cx="12" cy="12" r="4" /><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9 7 7m10 10 2.1 2.1M19.1 4.9 17 7M7 17l-2.1 2.1" /></>}
