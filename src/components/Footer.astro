---
const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const waLink = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <div>
        <img src="/logo.svg" alt="DG Inmobiliaria" class="h-8 w-auto mb-4" />
        <p class="text-sm">Mazatlán, Sinaloa, México</p>
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white">
          {whatsapp}
        </a>
      </div>

      <nav class="flex flex-col gap-2 text-sm">
        <a href="/" class="hover:text-white">Inicio</a>
        <a href="/propiedades" class="hover:text-white">Propiedades</a>
        <a href="/nosotros" class="hover:text-white">Nosotros</a>
        <a href="/contacto" class="hover:text-white">Contacto</a>
      </nav>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-6 text-xs text-gray-500">
      © {year} DG Inmobiliaria. Todos los derechos reservados.
    </div>
  </div>
</footer>
