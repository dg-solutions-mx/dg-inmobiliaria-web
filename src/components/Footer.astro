---
import Brand from './Brand.astro';
import Icon from './Icon.astro';
const WHATSAPP_URL = 'https://wa.me/526699334134?text=Hola%2C%20me%20interesa%20recibir%20asesor%C3%ADa%20inmobiliaria.';
---
<footer class="footer">
  <div class="footer-grid container">
    <div class="footer-brand">
      <Brand variant="footer" />
      <p>Asesoría inmobiliaria en Mazatlán, Sinaloa. Te acompañamos para que tomes una decisión clara y segura.</p>
      <div class="socials">
        <a href="#" aria-label="Instagram"><Icon name="instagram" size={18} /></a>
        <a href="#" aria-label="Facebook"><Icon name="facebook" size={18} /></a>
      </div>
    </div>
    <div class="footer-col">
      <h3>Enlaces rápidos</h3>
      <a href="#inicio">Inicio</a>
      <a href="#como-te-ayudamos">Cómo te ayudamos</a>
      <a href="#mazatlan">Mazatlán</a>
      <a href="#proceso">Proceso</a>
      <a href="#contacto">Contacto</a>
    </div>
    <div class="footer-col">
      <h3>Asesoría</h3>
      <span>Compra de vivienda</span>
      <span>Orientación personalizada</span>
      <span>Opciones de crédito</span>
      <span>Visitas y seguimiento</span>
    </div>
    <div class="footer-col footer-contact">
      <h3>Contacto</h3>
      <a href="tel:+526699334134"><Icon name="phone" size={17} /> 669 933 41 34</a>
      <span><Icon name="location" size={17} /> Mazatlán, Sinaloa</span>
      <a class="button button--outline-gold" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer"><Icon name="whatsapp" size={17} /> Escríbenos por WhatsApp</a>
    </div>
  </div>
  <div class="footer-bottom container">
    <span>© 2026 DG Inmobiliaria. Todos los derechos reservados.</span>
    <a href="#">Aviso de privacidad</a>
  </div>
</footer>
