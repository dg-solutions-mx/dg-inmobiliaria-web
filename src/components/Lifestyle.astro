---
import { Sun, Waves, UtensilsCrossed, Building2 } from 'lucide-astro';

const features = [
  { Icon: Sun, text: 'Clima ideal todo el año' },
  { Icon: Waves, text: 'Playas que enamoran' },
  { Icon: UtensilsCrossed, text: 'Vida y gastronomía local' },
  { Icon: Building2, text: 'Opciones residenciales' },
];
---
<section class="lifestyle" id="mazatlan">
  <div class="lifestyle-photo" data-reveal>
    <img src="/assets/mazatlan-lifestyle.webp" alt="Atardecer en la costa de Mazatlán" loading="lazy" data-parallax-lifestyle />
  </div>
  <div class="lifestyle-copy" data-reveal>
    <div class="contour-lines" aria-hidden="true"></div>
    <p class="eyebrow">Mazatlán, un estilo de vida</p>
    <h2>Vive el encanto del mar,<br /> la ciudad y su gente.</h2>
    <p class="lifestyle-copy__lead">Mazatlán combina playa, vida cotidiana y nuevas oportunidades para encontrar un hogar en una ciudad que se disfruta todos los días.</p>
    <div class="lifestyle-features">
      {features.map((feature) => (
        <div>
          <feature.Icon size={29} stroke-width={1.5} />
          <span>{feature.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
