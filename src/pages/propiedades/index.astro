---
import Layout from '@/layouts/Layout.astro';
import PropertyCard from '@/components/PropertyCard.astro';
import { supabase } from '@/lib/supabase';

// const { data: propiedades } = await supabase.from('propiedades').select('*');
const propiedades: any[] = [];
---

<Layout title="Propiedades" description="Explora terrenos y desarrollos en Mazatlán, Sinaloa.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Propiedades</h1>

    {propiedades.length === 0 ? (
      <p class="text-gray-500">Próximamente disponibles.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {propiedades.map((p) => (
          <PropertyCard
            slug={p.slug}
            title={p.title}
            zone={p.zone}
            price={p.price}
            imageUrl={p.image_url}
            type={p.type}
          />
        ))}
      </div>
    )}
  </section>
</Layout>
